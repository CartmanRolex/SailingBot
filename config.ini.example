[credentials]
; Your UNIL email address or card ID
email = your_unil_email_or_card_id@example.com
; Your UNIL sports account password
password = your_password_here

[telegram]
; Get a bot token from @BotFather on Telegram
bot_token = 123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
; Your Telegram chat ID (send /start to @userinfobot to find yours)
chat_id = 123456789

[settings]
; How often to check for available courses (in seconds)
poll_interval_seconds = 300
; URL of the course listing/registration page
course_url = https://www2.unil.ch/sportres/nautique/inscriptions.php
; Log file path (relative to script directory)
log_file = sailing_bot.log

[filters]
; Comma-separated list of course types to watch (leave empty = all courses)
; Available types: Dériveur simple, Dériveur double, Catamaran, Entraînement à la régate
course_types =
; Comma-separated list of instructors to watch (leave empty = all instructors)
; Partial matches work, e.g. "Mar" matches "Marine"
instructors =
